# ===================================================================
# IBIS-X — Variables d'environnement pour `make dev` (Minikube local).
# Copier ce fichier en `.env` à la racine puis remplir les valeurs.
#
# Les 8 variables ci-dessous sont TOUTES OBLIGATOIRES.
# Le script `scripts/development/update-local-secrets.py` sort avec
# `exit 1` si l'une d'entre elles est vide ou absente.
# ===================================================================

# --- Auth JWT (api-gateway) -----------------------------------------
JWT_SECRET_KEY=replace_with_64_char_hex_generated_via_openssl_rand_hex_32

# --- Base de données PostgreSQL (partagée entre services) -----------
# Source de vérité : k8s/base/postgres/postgresql-statefulset.yaml
#   POSTGRES_USER = ibis_x_user
#   POSTGRES_DB   = ibis_x_db
#   Namespace K8s = ibis-x
# Les secrets K8s générés par update-local-secrets.py sont alignés sur cette URL.
DATABASE_URL=postgresql+asyncpg://ibis_x_user:password@postgresql-service.ibis-x.svc.cluster.local:5432/ibis_x_db

# --- OAuth Google (api-gateway) -------------------------------------
GOOGLE_CLIENT_ID=votre-client-id-google.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre-client-secret-google

# URL de redirection OAuth côté frontend pour le flow de callback.
# En local, correspond au port-forward frontend (8080).
OAUTH_REDIRECT_URL=http://localhost:8080/authentication/callback

# --- Kaggle (service-selection, import datasets) --------------------
# Laisser des placeholders si tu ne testes pas l'import Kaggle —
# des chaines vides font échouer update-local-secrets.py.
KAGGLE_USERNAME=placeholder-kaggle-username
KAGGLE_KEY=placeholder-kaggle-key

# --- OpenAI (xai-engine chatbot + ml-pipeline analyse IA) -----------
# Placeholder accepté si tu ne testes pas les features LLM.
OPENAI_API_KEY=sk-proj-PLACEHOLDER_REPLACE_ME

# ===================================================================
# Les variables ci-dessous sont OPTIONNELLES — défauts dans le code.
# ===================================================================

# OpenAI (consommé par xai-engine uniquement)
OPENAI_MODEL=gpt-5-nano
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_REASONING_EFFORT=low

# Chat xai-engine
MAX_CHAT_QUESTIONS=5
CHAT_SESSION_TIMEOUT_HOURS=24
MAX_TOKENS_PER_QUESTION=200

# URL de redirection OAuth pour PROD Azure (injectée via GitHub Actions
# en prod, pas utilisée en local).
# OAUTH_REDIRECT_URL_PROD=https://your-domain.com/authentication/callback
